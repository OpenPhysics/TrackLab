{
  "name": "trackLab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "release": "npm version patch && git push && git push --tags",
    "check": "tsc --noEmit",
    "serve": "serve -s dist",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
